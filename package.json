{
  "name": "naru-memory-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bench": "tsx scripts/bench.ts",
    "build": "pnpm --filter @narulabs/naru build",
    "demo": "tsx examples/walkthrough.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "naru": "tsx apps/cli/src/index.ts",
    "pack-smoke": "bash scripts/pack-smoke.sh",
    "release": "changeset publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.31.0",
    "@naru/core": "workspace:*",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
