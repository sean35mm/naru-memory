{
  "name": "naru-memory",
  "version": "0.1.0",
  "description": "Local-first, harness-agnostic memory for AI agents and developer workflows",
  "license": "MIT",
  "homepage": "https://github.com/sean35mm/naru-memory#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sean35mm/naru-memory.git",
    "directory": "apps/cli"
  },
  "bugs": "https://github.com/sean35mm/naru-memory/issues",
