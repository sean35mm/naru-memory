  },
  "devDependencies": {
    "@naru/api": "workspace:*",
    "@naru/core": "workspace:*",
    "@naru/opencode-adapter": "workspace:*",
    "@naru/schema": "workspace:*",
    "@naru/server": "workspace:*",
    "tsup": "^8.0.0"
